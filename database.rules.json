{
  "rules": {
    ".read": false,
    ".write": false,
    "vault": {
      ".read": true,
      "$postId": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid || auth.token.admin === true)",
        ".validate": "newData.hasChildren(['title', 'content', 'authorId', 'authorName', 'timestamp', 'supportCount'])",
        "supportCount": {
          ".write": "auth != null"
        }
      }
    },
    "vaultSupports": {
      "$postId": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
          ".write": "auth != null && auth.uid === $uid && (!data.exists() || newData.val() === null)",
          ".validate": "newData.val() === true || newData.val() === null"
        }
      }
    },
    "liveCounters": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "activityFeed": {
      ".read": true,
      "$activityId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['action', 'details', 'userId', 'timestamp']) && newData.child('userId').val() === auth.uid"
      }
    }
  }
}
